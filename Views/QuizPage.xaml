<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="KanaLearning.Views.QuizPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" ColumnSpacing="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*" />
            <ColumnDefinition Width="4*" />
        </Grid.ColumnDefinitions>

        <!-- Quiz Area -->
        <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="24">
            <StackPanel Spacing="16">
                <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding PageTitleText}" />
                
                <TextBlock FontSize="64" Text="{Binding CurrentKanaText}" HorizontalAlignment="Center" Margin="0,16" />
                
                <TextBox Header="{Binding AnswerLabelText}" Text="{Binding UserAnswer, Mode=TwoWay}" PlaceholderText="{Binding AnswerPlaceholderText}" />
                
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding SubmitAnswerCommand}" Content="{Binding SubmitButtonText}" Style="{StaticResource AccentButtonStyle}" />
                    <Button Command="{Binding NextQuestionCommand}" Content="{Binding NextButtonText}" />
                    <Button Command="{Binding ResetSessionCommand}" Content="{Binding ResetButtonText}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="{Binding ProgressText}" />
                    <TextBlock Text="{Binding AccuracyText}" />
                </StackPanel>
                
                <TextBlock Text="{Binding FeedbackMessage}" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />

                <MenuFlyoutSeparator Margin="0,8" />
                
                <TextBlock Text="{Binding FiltersTitleText}" FontWeight="SemiBold" />
                <Grid RowSpacing="8" ColumnSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Row="0" Grid.Column="0" Content="{Binding FilterHiraganaText}" IsChecked="{Binding IncludeHiragana, Mode=TwoWay}" />
                    <CheckBox Grid.Row="0" Grid.Column="1" Content="{Binding FilterKatakanaText}" IsChecked="{Binding IncludeKatakana, Mode=TwoWay}" />
                    <CheckBox Grid.Row="1" Grid.Column="0" Content="{Binding FilterDakutenText}" IsChecked="{Binding IncludeDakutenHandakuten, Mode=TwoWay}" />
                    <CheckBox Grid.Row="1" Grid.Column="1" Content="{Binding FilterYoonText}" IsChecked="{Binding IncludeYoon, Mode=TwoWay}" />
                </Grid>
                <TextBlock Text="{Binding FilteredCountText}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Question Bank Area -->
        <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="24">
            <StackPanel Spacing="16">
                <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding ManualInputTitleText}" />
                
                <Button Click="OnImportButtonClick" Content="{Binding ImportButtonText}" HorizontalAlignment="Stretch" />
                <TextBlock Text="{Binding ImportHintText}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                <MenuFlyoutSeparator Margin="0,8" />

                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Manual Entry" />
                
                <ComboBox Header="{Binding ManualCategoryLabelText}" ItemsSource="{Binding CategoryOptions}" SelectedItem="{Binding SelectedManualCategory, Mode=TwoWay}" HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                
                <TextBox Header="{Binding ManualKanaLabelText}" Text="{Binding ManualKana, Mode=TwoWay}" />
                <TextBox Header="{Binding ManualRomajiLabelText}" Text="{Binding ManualRomaji, Mode=TwoWay}" />
                <Button Command="{Binding AddQuestionCommand}" Content="{Binding AddButtonText}" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" />
                <TextBlock Text="{Binding BankFeedbackMessage}" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
