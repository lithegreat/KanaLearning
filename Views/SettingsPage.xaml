<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="KanaLearning.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Padding="24" Spacing="14">
        <TextBlock FontSize="28" FontWeight="Bold" Text="{Binding TitleText}" />

        <TextBlock Text="{Binding DescriptionText}" TextWrapping="Wrap" />

        <ComboBox
            AutomationProperties.Name="Language"
            Header="{Binding LanguageText}"
            ItemsSource="{Binding LanguageOptions}"
            SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
    </StackPanel>
</Page>
